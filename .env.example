##############################################################################
# CONSTELLATION — Treasury Copilot (X Layer / OKX).
# Every variable is documented with a one-line comment. No secrets committed.
##############################################################################

# ── X Layer chain (eip155:196) ──────────────────────────────────────────────
# TODO(unverified): confirm RPC + chain id on Day 1 before any live read.
# Do NOT hardcode a third-party RPC in code; it is read from here.
XLAYER_RPC=                        # TODO(unverified) e.g. https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196
XLAYER_EXPLORER=https://www.oklink.com/x-layer

# ── Tracked tokens on X Layer ───────────────────────────────────────────────
# TODO(unverified): fill real contract addresses on Day 1. Never invent these —
# a wrong token address makes every revenue report silently wrong.
USDT_ADDRESS=                      # TODO(unverified) USDT on X Layer, 6 decimals (confirm)
USDT_DECIMALS=6
USDG_ADDRESS=                      # TODO(unverified) USDG on X Layer, decimals (confirm)
USDG_DECIMALS=6
# Native gas token is OKB (18 decimals) — balance/gas read from the node, no address.

# ── Indexer / Postgres ──────────────────────────────────────────────────────
DATABASE_URL=postgres://constellation:constellation@localhost:5432/constellation
POSTGRES_USER=constellation
POSTGRES_PASSWORD=constellation
POSTGRES_DB=constellation
POSTGRES_PORT=5432
INDEXER_START_BLOCK=0              # block to index registered wallets from
INDEXER_MAX_RANGE_PER_CALL=100    # getLogs chunk size — X Layer public RPC caps at 100 blocks/call

# ── Treasury MCP server ─────────────────────────────────────────────────────
TREASURY_PORT=7801
REGISTER_NONCE_TTL_SECONDS=600     # EIP-191 challenge validity (10 minutes)

# ── Payment adapter ─────────────────────────────────────────────────────────
# Nothing outside packages/payment-adapter may import a payment SDK.
# mock = documented no-charge test path (default, and what a fresh deploy runs).
# sdk  = real OKX facilitator (non-custodial: OKX verifies + settles; we hold no
#        key). sdk is OPERATIONALLY gated — keep prod on mock until one real buyer
#        replay returns PAYMENT-RESPONSE + a confirmed X Layer tx, THEN flip this.
PAYMENT_MODE=mock                  # mock | sdk
# sdk-mode credentials (required only when PAYMENT_MODE=sdk). Set as Fly secrets,
# never commit. Create in the OKX Web3 Developer Portal (web3.okx.com dev portal):
# one project issues all three. Missing any of them makes sdk mode fail-closed.
OKX_API_KEY=                       # OKX Web3 API key
OKX_SECRET_KEY=                    # OKX Web3 API secret (HMAC-SHA256 signing)
OKX_PASSPHRASE=                    # passphrase you set at key creation
OKX_FACILITATOR_BASE_URL=          # optional override; defaults to https://web3.okx.com

# ── packages/erc8004 — registry READ clients for KYA ───────────────────────
# TODO(unverified): no ERC-8004 registry address has been human-verified on any
# chain. Unset = that chain's reads are disabled (NOT_CONFIGURED), never guessed.
ETHEREUM_RPC=                      # TODO(unverified) Ethereum mainnet RPC
BASE_RPC=                          # TODO(unverified) Base mainnet RPC
ERC8004_IDENTITY_REGISTRY_ETH=     # TODO(unverified) identity registry (ERC-721) on Ethereum
ERC8004_REPUTATION_REGISTRY_ETH=   # TODO(unverified) reputation registry on Ethereum
ERC8004_IDENTITY_REGISTRY_BASE=    # TODO(unverified) identity registry (ERC-721) on Base
ERC8004_REPUTATION_REGISTRY_BASE=  # TODO(unverified) reputation registry on Base

# ── Dashboard (apps/dashboard) ──────────────────────────────────────────────
# Public MCP endpoint the read-only demo dashboard calls (free-tool path).
NEXT_PUBLIC_TREASURY_MCP_URL=https://constellationokx.fly.dev/mcp
