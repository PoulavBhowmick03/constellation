##############################################################################
# CONSTELLATION — Treasury Copilot (X Layer). Everything below the Celo banner
# is LEGACY LedgerForge config, kept as harvest source during the repurpose.
##############################################################################

# ── X Layer chain (eip155:196) ──────────────────────────────────────────────
# TODO(unverified): confirm RPC + chain id on Day 1 before any live read.
# Do NOT hardcode a third-party RPC in code; it is read from here.
XLAYER_RPC=                        # TODO(unverified) e.g. https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196
XLAYER_EXPLORER=https://www.oklink.com/x-layer

# ── Tracked tokens on X Layer ───────────────────────────────────────────────
# TODO(unverified): fill real contract addresses on Day 1. Never invent these —
# a wrong token address makes every revenue report silently wrong.
USDT_ADDRESS=                      # TODO(unverified) USDT on X Layer, 6 decimals (confirm)
USDT_DECIMALS=6
USDG_ADDRESS=                      # TODO(unverified) USDG on X Layer, decimals (confirm)
USDG_DECIMALS=6
# Native gas token is OKB (18 decimals) — balance/gas read from the node, no address.

# ── Indexer / Postgres ──────────────────────────────────────────────────────
DATABASE_URL=postgres://constellation:constellation@localhost:5432/constellation
POSTGRES_USER=constellation
POSTGRES_PASSWORD=constellation
POSTGRES_DB=constellation
POSTGRES_PORT=5432
INDEXER_START_BLOCK=0              # block to index registered wallets from
INDEXER_MAX_RANGE_PER_CALL=100    # getLogs chunk size — X Layer public RPC caps at 100 blocks/call

# ── Treasury MCP server ─────────────────────────────────────────────────────
TREASURY_PORT=7801
REGISTER_NONCE_TTL_SECONDS=600     # EIP-191 challenge validity (10 minutes)

# ── Payment adapter ─────────────────────────────────────────────────────────
# Nothing outside packages/payment-adapter may import a payment SDK.
# mock = documented no-charge test path (default, and what a fresh deploy runs).
# sdk  = real OKX facilitator (non-custodial: OKX verifies + settles; we hold no
#        key). sdk is OPERATIONALLY gated — keep prod on mock until one real buyer
#        replay returns PAYMENT-RESPONSE + a confirmed X Layer tx, THEN flip this.
PAYMENT_MODE=mock                  # mock | sdk
# sdk-mode credentials (required only when PAYMENT_MODE=sdk). Set as Fly secrets,
# never commit. Create in the OKX Web3 Developer Portal (web3.okx.com dev portal):
# one project issues all three. Missing any of them makes sdk mode fail-closed.
OKX_API_KEY=                       # OKX Web3 API key
OKX_SECRET_KEY=                    # OKX Web3 API secret (HMAC-SHA256 signing)
OKX_PASSPHRASE=                    # passphrase you set at key creation
OKX_FACILITATOR_BASE_URL=          # optional override; defaults to https://web3.okx.com

# ── packages/erc8004 — registry READ clients for KYA ───────────────────────
# TODO(unverified): no ERC-8004 registry address has been human-verified on any
# chain. Unset = that chain's reads are disabled (NOT_CONFIGURED), never guessed.
ETHEREUM_RPC=                      # TODO(unverified) Ethereum mainnet RPC
BASE_RPC=                          # TODO(unverified) Base mainnet RPC
ERC8004_IDENTITY_REGISTRY_ETH=     # TODO(unverified) identity registry (ERC-721) on Ethereum
ERC8004_REPUTATION_REGISTRY_ETH=   # TODO(unverified) reputation registry on Ethereum
ERC8004_IDENTITY_REGISTRY_BASE=    # TODO(unverified) identity registry (ERC-721) on Base
ERC8004_REPUTATION_REGISTRY_BASE=  # TODO(unverified) reputation registry on Base

# ── Celo Network (mainnet; for mainnet use 42220 + forno.celo.org) ──
CELO_RPC=https://forno.celo.org
CELO_CHAIN_ID=42220
CELO_EXPLORER=https://celoscan.io
CELOSCAN_API_KEY=                # for `forge script --verify`

# ── Keys (NEVER commit real values) ───────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x          # wallet used for `forge script --broadcast`
OPERATOR_PRIVATE_KEY=0x          # facilitator hot wallet; must be on ERC-8004 allowlist

# ── Deployed Contracts (fill after `forge script Deploy.s.sol --broadcast`) ───
SKILL_REGISTRY_ADDRESS=
X402_ESCROW_ADDRESS=
BAZAAR_LISTINGS_ADDRESS=

# ── ERC-8004 — not yet deployed on Celo; leave blank to use graceful fallback ─
# SkillRegistry try/catches the identity registry call, so blank = local-only
# reputation. Fill once an ERC-8004 deployment exists on Celo.
ERC8004_REPUTATION_REGISTRY=
ERC8004_IDENTITY_REGISTRY=

# ── Tokens (Celo) ───────────────────────────────────────────────────
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a   # cUSD on Celo mainnet
USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C   # USDC on Celo mainnet

# ── Facilitator ────────────────────────────────────────────────────────────────
OPERATOR_ADDRESS=            # address derived from OPERATOR_PRIVATE_KEY
PROVIDER_ADDRESS=            # recipient of provider payouts from escrow; must differ from OPERATOR_ADDRESS
                             # run: cast wallet address --private-key $OPERATOR_PRIVATE_KEY
FACILITATOR_PORT=3001
FACILITATOR_FEE_BPS=20           # 0.2% taken from each settlement before paying provider
FACILITATOR_MIN_AMOUNT=100       # minimum payment in token base units (= 0.0001 USDC)

# ── Bazaar / Dashboard ─────────────────────────────────────────────────────────
BAZAAR_API_PORT=3002
NEXT_PUBLIC_FACILITATOR_URL=http://localhost:3001
NEXT_PUBLIC_BAZAAR_API=http://localhost:3002

# ── Spawn Protocol demo skills ────────────────────────────────────────────────
SPAWN_API_URL=http://localhost:3004
SPAWN_AGENT_PORT=3003
SPAWN_SKILL_BASE_URL=http://localhost:3003
SPAWN_PROVIDER_ADDRESS=            # provider wallet paid by the facilitator
CONSUMER_PRIVATE_KEY=0x             # demo consumer wallet; must hold USDC and approve OPERATOR_ADDRESS
DEMO_LINEAGE_KEY=demo-lineage
DEMO_GENERATION=1

# ── Mantle data skills (no external API key required) ─────────────────────────
MANTLE_SKILL_PORT=3005
MANTLE_SKILL_BASE_URL=http://localhost:3005

# ── Byreal skills (Solana CLMM + Perps, no API key required) ─────────────────
BYREAL_SKILL_PORT=3006
BYREAL_SKILL_PUBLIC_URL=https://ledgerforge-byreal.fly.dev

# ── Elfa AI Skills (20,000 bonus credits, expires 2026-07-01) ────────
ELFA_API_KEY=                    # from elfa.ai API dashboard
ELFA_SKILL_PORT=3007
ELFA_SKILL_PUBLIC_URL=https://ledgerforge-elfa.fly.dev

# ── API Keys ───────────────────────────────────────────────────────────────────
MANTLESCAN_API_KEY=              # from https://mantlescan.xyz/myapikey — needed for contract verification
