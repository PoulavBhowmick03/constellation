{
  "name": "@constellation/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "X Layer (eip155:196) ledger indexer: USDT/USDG ERC-20 transfers, native OKB balance snapshots, per-tx gas. Postgres-backed. Read-only against chain.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/migrate.ts",
    "index": "tsx src/run.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
